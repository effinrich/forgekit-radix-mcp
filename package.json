{
  "name": "forgekit-radix-mcp",
  "version": "0.1.0",
  "description": "MCP server that exposes Radix Primitives' APIs and accessibility contracts to AI coding agents, so Claude/Cursor stop hallucinating props and respect the ARIA contract.",
  "author": "Rich Tillman <richtillman@gmail.com>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "forgekit-radix-mcp": "./dist/cli.js",
    "radix-mcp": "./dist/cli.js"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "radix-ui",
    "radix",
    "accessibility",
    "a11y",
    "design-system",
    "ai",
    "claude",
    "cursor"
  ],
  "homepage": "https://github.com/effinrich/forgekit-radix-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/effinrich/forgekit-radix-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/effinrich/forgekit-radix-mcp/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --clean --tsconfig tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.6.0",
    "vitest": "^4.1.8"
  }
}
